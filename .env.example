# Spira Instance Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

SPIRA_URL=https://your-company.spiraservice.net
SPIRA_USERNAME=your_username
SPIRA_API_KEY={00000000-0000-0000-0000-000000000000}
SPIRA_PROJECT_ID=1
SPIRA_TEST_SET_ID=1
SPIRA_RELEASE_ID=1

# Auto-create test cases if they don't exist (true/false)
# Default: true
SPIRA_AUTO_CREATE_TEST_CASES=true

# Auto-create test sets if they don't exist (true/false)
# Default: true
SPIRA_AUTO_CREATE_TEST_SETS=true

# Spira custom property field name for automation test case ID lookup
# Used to match test results to existing Spira test cases via a stable hash
# e.g. Custom_04 - must match the property configured in your Spira template
# SPIRA_AUTOMATION_ID_FIELD=Custom_04

# Optional: Test case mapping file
SPIRA_MAPPING_FILE=examples/test-case-mappings.json

# Optional: Test results file for testing
SPIRA_RESULTS_FILE=examples/sample-allure-results.json
